# Database (PostgreSQL — Supabase, PlanetScale-compatible, or self-hosted)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nextreport"

# NextAuth
AUTH_SECRET="replace-with-a-random-32-byte-secret"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App
NEXTAUTH_URL="http://localhost:3000"

# File storage for generated reports.
# Local dev: leave BLOB_READ_WRITE_TOKEN unset — falls back to local disk (STORAGE_DIR).
# Production (Vercel): enable Blob storage on the project (Storage tab → Create
# Database → Blob) — it auto-injects BLOB_READ_WRITE_TOKEN, don't set it by hand.
STORAGE_DIR="./storage"
BLOB_READ_WRITE_TOKEN=""

# Per-client Groq/Gemini API keys are entered in the app UI (Client settings),
# not here — see the "AI insight writing" fieldset on each client's page.
