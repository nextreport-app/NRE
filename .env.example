# Database (PostgreSQL — Supabase, PlanetScale-compatible, or self-hosted)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nextreport"

# NextAuth
AUTH_SECRET="replace-with-a-random-32-byte-secret"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App
NEXTAUTH_URL="http://localhost:3000"

# File storage for generated reports — required in every environment,
# including local dev (no local-disk fallback: Vercel's serverless functions
# have no writable filesystem to hand a file from one request to the next).
# On Vercel: enable Blob storage on the project (Storage tab → Create Database
# → Blob) and connect it — this auto-injects BLOB_READ_WRITE_TOKEN, don't set
# it by hand there. Locally: run `vercel env pull .env` after connecting Blob
# storage to pull the same token down, or generate a token from the Vercel
# dashboard's Blob store settings.
BLOB_READ_WRITE_TOKEN=""

# Per-client Groq/Gemini API keys are entered in the app UI (Client settings),
# not here — see the "AI insight writing" fieldset on each client's page.
